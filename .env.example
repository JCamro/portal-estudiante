# ===========================================
# VARIABLES DE ENTORNO - PRODUCCIÓN
# ===========================================
# Copia este archivo como .env y completa los valores

# -------------------------------------------
# API
# -------------------------------------------

# URL del backend Django (sin trailing slash)
# Producción: URL de Railway o tu servidor
VITE_API_URL=https://tu-backend.up.railway.app

# Ambiente: development | production
VITE_ENVIRONMENT=production

# -------------------------------------------
# DEPLOYMENT
# -------------------------------------------

# Vercel:
# 1. Importar repositorio GitHub
# 2. Framework: Vite
# 3. Build command: npm run build
# 4. Output directory: dist
# 5. Agregar variable en Settings > Environment Variables:
#    - VITE_API_URL = https://tu-backend.up.railway.app
#
# Railway (backend):
# 1. Verificar que CORS_ALLOWED_ORIGINS incluya el dominio de Vercel
#    Ejemplo: CORS_ALLOWED_ORIGINS=https://tu-portal.vercel.app
